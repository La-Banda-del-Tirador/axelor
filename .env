# ─── Versión de Axelor ────────────────────────────────────
AXELOR_VERSION=8.5

# ─── Base de datos ────────────────────────────────────────
POSTGRES_USER=axelor
POSTGRES_PASSWORD=axelor
POSTGRES_DB=axelor

# ─── Aplicación ───────────────────────────────────────────
APP_PORT=8740
APP_USER=admin
APP_PASS=admin
APP_NAME=Mi ERP
APP_LANGUAGE=es
APP_DEMO_DATA=true

# ─── JVM ──────────────────────────────────────────────────
# Aumentar si la máquina tiene más RAM disponible
JAVA_XMX=2048m

# ─── pgAdmin (gestor visual de BD) ────────────────────────
PGADMIN_PORT=8741
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin
